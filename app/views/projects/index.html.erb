<h1>Community Projects</h1>
<table>
  <tr>
    <th>Name</th>
    <th>Cost</th>
  </tr>
  <% @projects.each do |project| %>
    <tr>
      <td><%= project.name %></td>
      <td>$<%= project.cost %></td>
    </tr>
  <% end %>
</table>
<% unless current_user.admin? %>
  <%= link_to "Allocate My Budget", new_allocation_path %>
<% end %>

