<h1>Admin Allocation Report</h1>
<table>
  <tr>
    <th>Project</th>
    <th>Required Funding</th>
    <th>Total Allocated</th>
  </tr>
  <% @projects.each do |project| %>
    <tr>
      <td><%= project.name %></td>
      <td>$<%= project.cost %></td>
      <td>$<%= project.total_funded %></td>
    </tr>
  <% end %>
</table>
